# Backend Configuration
DEVICE=cpu
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=True
CORS_ORIGINS=["*"]

# Model Settings
DEFAULT_MODEL=yolov8
CONFIDENCE_THRESHOLD=0.5
IOU_THRESHOLD=0.45

# Tracking Settings
MAX_TRACK_AGE=30
MIN_TRACK_CONFIDENCE=0.3
TRACKER_TYPE=deepsort

# Redis Configuration
REDIS_URL=redis://localhost:6379

# HuggingFace
# Set your Hugging Face token here (get from https://huggingface.co/settings/tokens)
HF_TOKEN=
HF_CACHE_DIR=./models

# Performance
ENABLE_FP16=False
MAX_FRAME_SIZE=[1280,720]
MOBILE_FRAME_SIZE=[640,480]
